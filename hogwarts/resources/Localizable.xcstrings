    "help.faq.login.q": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كيف أسجل الدخول؟"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How do I sign in?"
          }
        }
      }
    },
    "help.faq.login.a": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم البريد الإلكتروني وكلمة المرور التي زودتك بها مدرستك. يمكنك أيضًا تسجيل الدخول باستخدام Apple أو Google أو Facebook إذا كان حسابك مرتبطًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the email and password issued by your school. You can also sign in with Apple, Google, or Facebook if your account is linked."
          }
        }
      }
    },
    "help.faq.biometric.q": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل يمكنني فتح التطبيق ببصمة الوجه أو الإصبع؟"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can I unlock with Face ID or Touch ID?"
          }
        }
      }
    },
    "help.faq.biometric.a": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نعم — افتح الملف الشخصي، ثم فعّل بصمة الوجه أو الإصبع. سيستخدمها التطبيق للفتح في المرة القادمة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yes — open Profile, then enable Face ID or Touch ID. The app will use it to unlock the next time you open it."
          }
        }
      }
    },
    "help.faq.language.q": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كيف أغير اللغة؟"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How do I change the language?"
          }
        }
      }
    },
    "help.faq.language.a": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح الملف الشخصي ← اللغة واختر العربية أو الإنجليزية. يتبدل التطبيق فورًا دون إعادة تشغيل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Profile → Language and pick Arabic or English. The app switches instantly without restarting."
          }
        }
      }
    },
    "help.faq.notifications.q": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لماذا لا تصلني الإشعارات؟"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Why am I not getting notifications?"
          }
        }
      }
    },
    "help.faq.notifications.a": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تأكد من السماح بالإشعارات في إعدادات iOS ← Hogwarts ← الإشعارات، ومن تفعيلها لحساب مدرستك في الملف الشخصي."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make sure notifications are allowed in iOS Settings → Hogwarts → Notifications, and that your school account has notifications enabled in Profile."
          }
        }
      }
    },
    "help.faq.offline.q": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل يعمل التطبيق دون اتصال؟"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Does the app work offline?"
          }
        }
      }
    },
    "help.faq.offline.a": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُحفظ البيانات الحديثة للقراءة دون اتصال. تُحفظ الإجراءات في قائمة انتظار وتتم مزامنتها بمجرد عودة الاتصال."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent data is cached for offline reading. Actions you take while offline are queued and synced once you're back online."
          }
        }
      }
    },
    "help.faq.switchSchool.q": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كيف أبدّل بين المدارس؟"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How do I switch schools?"
          }
        }
      }
    },
    "help.faq.switchSchool.a": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا كان حسابك يخص أكثر من مدرسة، سجّل الخروج ثم الدخول لاختيار مدرسة أخرى."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If your account belongs to more than one school, sign out and sign back in to pick a different school."
          }
        }
      }
    },
